# Managed by chezmoi (home/dot_config/mise/config.toml.tmpl).
# Single declarative tool manifest for the fleet. chezmoi owns dotfiles + this
# manifest; mise owns the tools. New machine: chezmoi apply -> mise install.
#
# Tiering:
#   foundation  -> exact pins, every host. Critical path (nvim/LazyVim, node,
#                  go, lazygit) must never silently move and break.
#   utility     -> float (latest); stable CLIs where churn is harmless.
#   coding CLIs -> float (latest), fhh-toolkit hosts only. They ship daily;
#                  pinning them just creates lag. Upgrades are intentional;
#                  chezmoi only runs `mise install` when this manifest changes.

[tools]
# --- foundation (exact pins, all hosts) ---
node = "22.22.2"
neovim = "0.12.3"
lazygit = "0.62.0"
go = "1.25.9"

# --- pinned utilities (all hosts) ---
# Pinned (not float) so the fleet stays on one version. Bumping this is a
# manifest *change* that fires the run_onchange mise-install hook and converges
# every host on the next hourly chezmoi pull. To roll forward: bump, commit, push.
just = "1.53.0"

# --- terminal/workstation CLIs (float, all hosts) ---
starship = "latest"
fzf = "latest"
zoxide = "latest"
fd = "latest"
ripgrep = "latest"
bat = "latest"
eza = "latest"
atuin = "latest"
direnv = "latest"
yazi = "latest"
"github:joshmedeski/sesh" = "latest"
btop = "latest"
gh = "latest"
"aqua:dlvhdr/gh-dash" = "latest"

# --- utility CLIs (float, all hosts) ---
stern = "latest"
kubectx = "latest"
kubens = "latest"
watchexec = "latest"
hyperfine = "latest"
gum = "latest"
curlie = "latest"
glow = "latest"
lazydocker = "latest"

# --- Kubernetes operator CLIs (float, all hosts) ---
kubectl = "latest"
k9s = "latest"
k3d = "latest"

# --- Development environment / Kubernetes dev-loop CLIs (float, all hosts) ---
dagger = "latest"
skaffold = "latest"
"aqua:loft-sh/devpod" = "latest"
{{ if .hasFhhToolkit }}
# --- coding CLIs (PINNED, fhh-toolkit hosts only) ---
# Pinned (not float) so a version bump is a manifest *change* that fires the
# run_onchange mise-install hook and converges every host on the next hourly
# chezmoi pull. To roll the fleet forward: bump the version here, commit, push.
# Explicit pins bypass mise's minimum_release_age gate, so newer hosts still
# install the pinned build even if it's younger than their float-latest floor.
# Claude Code ships a native binary; avoid the npm wrapper's postinstall path.
claude = "2.1.191"
"npm:@openai/codex" = "0.142.3"
"npm:@earendil-works/pi-coding-agent" = "0.80.2"
{{ end -}}
