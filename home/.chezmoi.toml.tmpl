{{- /* Stable per-machine facts, computed once at `chezmoi init`.
      Runtime reachability (Bao, GitHub, services) is checked by run_after
      scripts so it can heal when ACLs or DNS change after init. */ -}}
{{- $hostname := .chezmoi.hostname -}}
{{- $role := "tiny" -}}
{{- if eq $hostname "spark-0cf9" }}{{ $role = "spark" }}{{ end -}}
{{- if eq $hostname "pi3" }}{{ $role = "pi" }}{{ end -}}
{{- if hasPrefix "desktop-" (lower $hostname) }}{{ $role = "laptop" }}{{ end -}}
{{- if eq $hostname "ingvild" }}{{ $role = "ingvild" }}{{ end -}}
{{- if hasPrefix "scw-" (lower $hostname) }}{{ $role = "scw-agent" }}{{ end -}}
{{- $isAgentHost := or (eq $role "spark") (eq $role "laptop") (eq $role "ingvild") (eq $role "scw-agent") -}}
[data]
    hostname = {{ $hostname | quote }}
    role = {{ $role | quote }}
    isAgentHost = {{ $isAgentHost }}
