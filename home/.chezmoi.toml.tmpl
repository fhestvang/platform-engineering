{{- /* Per-machine facts, computed once at `chezmoi init`. */ -}}
{{- $hostname := .chezmoi.hostname -}}
{{- $role := "tiny" -}}
{{- if eq $hostname "spark-0cf9" }}{{ $role = "spark" }}{{ end -}}
{{- if eq $hostname "pi3" }}{{ $role = "pi" }}{{ end -}}
{{- if hasPrefix "desktop-" (lower $hostname) }}{{ $role = "laptop" }}{{ end -}}
{{- $isAgentHost := or (eq $role "spark") (eq $role "laptop") -}}
{{- /* Is OpenBao reachable from here? (fleet boxes currently are NOT). */ -}}
{{- $baoProbe := output "sh" "-c" "BAO_ADDR=https://bao.olm-hops.ts.net bao kv get -field=api_key kv/projects/linear >/dev/null 2>&1 && echo yes || echo no" | trim -}}
[data]
    hostname = {{ $hostname | quote }}
    role = {{ $role | quote }}
    isAgentHost = {{ $isAgentHost }}
    baoReachable = {{ eq $baoProbe "yes" }}
