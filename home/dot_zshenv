# Universal zsh environment (chezmoi-managed; read by EVERY zsh — interactive,
# `zsh -c`, and scripts). Interactive-only settings stay in .zshrc.

# OpenBao endpoint: the address used to *reach* Bao. Not a secret, and it can't
# live in Bao (chicken-and-egg). Tailscale Service, port-less 443, cert trusted
# by the system store, so no VAULT_CACERT needed.
export VAULT_ADDR="https://bao.olm-hops.ts.net"

# mise-managed tools (node, nvim, codex, claude, pi, etc.) are exposed via
# shims. Keep this in .zshenv so non-interactive zsh commands see the same tool
# set as login shells.
_mise_shims="$HOME/.local/share/mise/shims"
if [ -d "$_mise_shims" ]; then
  case ":$PATH:" in
    *":$_mise_shims:"*) ;;
    *) PATH="$_mise_shims:$PATH" ;;
  esac
fi
unset _mise_shims
export PATH

# Make the user-local zsh's modules resolvable in NON-interactive shells too.
# The relocated (deb-extracted) zsh keeps its modules outside the compiled-in
# default path, so without this a subshell (e.g. carapace's shell-bridge) errors
# with "failed to load module zsh/zpty". Guarded, so it's a no-op on a system zsh.
_zsh_mod="$HOME/.local/opt/zsh-ubuntu/usr/lib/$(uname -m)-linux-gnu/zsh/${ZSH_VERSION}"
[ -d "$_zsh_mod" ] && module_path=("$_zsh_mod" $module_path)
unset _zsh_mod
