#!/bin/sh

set -eu

action="${1:-}"
target="${2:-${TMUX_PANE:-}}"

case "$action" in
  working|idle|blocked|question|waiting|help|done|seen|release) ;;
  *) exit 0 ;;
esac

[ -n "${TMUX:-}" ] || [ -n "$target" ] || exit 0
command -v tmux >/dev/null 2>&1 || exit 0

show_state() {
  if [ -n "$target" ]; then
    tmux show-options -wqv -t "$target" @codex_agent_state 2>/dev/null || true
  else
    tmux show-options -wqv @codex_agent_state 2>/dev/null || true
  fi
}

set_state() {
  if [ -n "$target" ]; then
    tmux set-option -wq -t "$target" @codex_agent_state "$1" 2>/dev/null || true
  else
    tmux set-option -wq @codex_agent_state "$1" 2>/dev/null || true
  fi
}

clear_state() {
  if [ -n "$target" ]; then
    tmux set-option -wqu -t "$target" @codex_agent_state 2>/dev/null || true
  else
    tmux set-option -wqu @codex_agent_state 2>/dev/null || true
  fi
}

ring_terminal_bell() {
  if [ -t 1 ]; then
    printf '\a' 2>/dev/null || true
    return
  fi

  tty_name="$(tty 2>/dev/null || true)"
  case "$tty_name" in
    /*)
      if [ -w "$tty_name" ]; then
        printf '\a' >"$tty_name" 2>/dev/null || true
      fi
      ;;
  esac
}

case "$action" in
  working)
    set_state working
    ;;
  blocked|question|waiting|help)
    set_state blocked
    ring_terminal_bell
    ;;
  done)
    set_state "done"
    ring_terminal_bell
    ;;
  idle)
    previous="$(show_state)"
    case "$previous" in
      working|blocked)
        set_state "done"
        ring_terminal_bell
        ;;
      *)
        clear_state
        ;;
    esac
    ;;
  seen)
    previous="$(show_state)"
    if [ "$previous" = "done" ]; then
      clear_state
    fi
    ;;
  release)
    clear_state
    ;;
esac

exit 0
