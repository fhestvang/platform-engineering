#!/usr/bin/env bash
set -euo pipefail

target="${OPEN_ON_LAPTOP_SSH:-laptop-win}"
mode="${OPEN_ON_LAPTOP_MODE:---new-window}"
log_file="${OPEN_ON_LAPTOP_LOG:-$HOME/.cache/open-on-laptop.log}"
method="${OPEN_ON_LAPTOP_METHOD:-task}"
ssh_opts=(-T -o BatchMode=yes -o RemoteCommand=none -o RequestTTY=no)

urls=("$@")
if [ "${#urls[@]}" -eq 0 ]; then
  while IFS= read -r line; do
    [ -n "$line" ] && urls+=("$line")
  done
fi

if [ "${#urls[@]}" -eq 0 ]; then
  exit 0
fi

notify() {
  local message="$1"
  if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
    tmux display-message "$message"
  else
    printf '%s\n' "$message" >&2
  fi
}

log() {
  mkdir -p "$(dirname "$log_file")"
  printf '%s %s\n' "$(date -Is)" "$*" >>"$log_file"
}

# Fast path: hand each URL to the laptop's default browser via `cmd /c start`.
# Over Windows SSH this can return success without opening in the interactive
# desktop session, so the default uses the scheduled-task bridge instead. Set
# OPEN_ON_LAPTOP_METHOD=start only for one-off debugging.
if [ "$method" = "start" ]; then
  log "target=$target method=start urls=${urls[*]}"
  rc=0
  for url in "${urls[@]}"; do
    safe="${url//\"/}"
    if ! ssh "${ssh_opts[@]}" "$target" "cmd.exe /c start \"\" \"$safe\""; then
      rc=1
    fi
  done
  if [ "$rc" -eq 0 ]; then
    log "ok target=$target method=start"
    exit 0
  fi
  log "failed target=$target method=start; falling back to scheduled task"
  notify "open-on-laptop: cmd start failed; trying scheduled task"
  method="task"
fi

encoded_urls=""
for url in "${urls[@]}"; do
  encoded_urls="${encoded_urls}  '$(printf '%s' "$url" | base64 -w0)'\n"
done

ps_script=$(cat <<PS
\$ErrorActionPreference = 'Stop'
\$ProgressPreference = 'SilentlyContinue'
\$method = '$(printf '%s' "$method" | sed "s/'/''/g")'
\$mode = '$(printf '%s' "$mode" | sed "s/'/''/g")'
\$urlsBase64 = @(
$(printf '%b' "$encoded_urls")
)
\$root = Join-Path \$env:LOCALAPPDATA 'SparkOpenUrl'
if (\$method -eq 'task') {
  New-Item -ItemType Directory -Force -Path \$root | Out-Null
  \$queuePath = Join-Path \$root 'urls.txt'
  Set-Content -Path \$queuePath -Value \$urlsBase64 -Encoding ASCII
  Start-ScheduledTask -TaskName 'SparkOpenUrl'
  \$remaining = \$urlsBase64
  for (\$i = 0; \$i -lt 60; \$i++) {
    Start-Sleep -Milliseconds 100
    if (-not (Test-Path \$queuePath)) { \$remaining = @(); break }
    \$remaining = Get-Content -Path \$queuePath -ErrorAction SilentlyContinue |
      Where-Object { -not [string]::IsNullOrWhiteSpace(\$_) }
    if (-not \$remaining -or \$remaining.Count -eq 0) { break }
  }
  if (-not \$remaining -or \$remaining.Count -eq 0) {
    exit 0
  }
  \$urlsBase64 = \$remaining
  throw "SparkOpenUrl scheduled task did not consume \$queuePath"
}
\$chromeCandidates = @(
  "\$env:ProgramFiles\\Google\\Chrome\\Application\\chrome.exe",
  "\${env:ProgramFiles(x86)}\\Google\\Chrome\\Application\\chrome.exe",
  "\$env:LOCALAPPDATA\\Google\\Chrome\\Application\\chrome.exe"
)
\$chrome = \$chromeCandidates | Where-Object { Test-Path \$_ } | Select-Object -First 1
if (-not \$chrome) {
  \$chrome = 'chrome.exe'
}
foreach (\$encodedUrl in \$urlsBase64) {
  \$url = [Text.Encoding]::UTF8.GetString([Convert]::FromBase64String(\$encodedUrl))
  if ([string]::IsNullOrWhiteSpace(\$mode)) {
    Start-Process -FilePath \$chrome -ArgumentList \$url | Out-Null
  } else {
    Start-Process -FilePath \$chrome -ArgumentList @(\$mode, \$url) | Out-Null
  }
}
Start-Sleep -Milliseconds 150
try {
  \$shell = New-Object -ComObject WScript.Shell
  if (-not \$shell.AppActivate('Google Chrome')) {
    \$shell.AppActivate('Chrome') | Out-Null
  }
} catch {}
PS
)

encoded_command=$(printf '%s' "$ps_script" | iconv -f UTF-8 -t UTF-16LE | base64 -w0)

log "target=$target method=$method mode=$mode urls=${urls[*]}"
if ! ssh "${ssh_opts[@]}" "$target" powershell.exe -NoProfile -NonInteractive -EncodedCommand "$encoded_command"; then
  log "failed target=$target method=$method"
  notify "open-on-laptop: failed to open Chrome via SSH host '$target'"
  exit 1
fi
log "ok target=$target method=$method"
