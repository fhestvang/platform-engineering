{{ if or (eq .role "tiny") (eq .role "pi") (eq .role "ingvild") (eq .role "scw-agent") -}}
#!/usr/bin/env bash
# Headless tailscale hosts (tinys, pi, ingvild, Scaleway agent hosts) lose accept-dns
# on reboot, which stops bao.<tailnet> from resolving and breaks every
# Bao-dependent step (atuin login, scw/linear wrappers). Laptop/spark manage DNS
# via the GUI client and are excluded. Re-assert it on each converge so DNS
# self-heals. {{ .hostname }}
command -v tailscale >/dev/null 2>&1 || exit 0
tailscale set --accept-dns=true 2>/dev/null || true
{{- else -}}
#!/usr/bin/env bash
# {{ .hostname }}: not a headless tailnet host; Tailscale DNS managed elsewhere.
exit 0
{{- end }}
